# =============================================================================
# arcadia-frontend — environment variables
# Copy this file to .env.local and fill in your values.
#
# This repo is FRONTEND ONLY. It contains no server code, no question banks,
# no signing keys, and no API routes. All /api/* requests are proxied to the
# arcadia-backend service via BACKEND_URL.
# =============================================================================

# =============================================================================
# REQUIRED — Backend proxy target
# =============================================================================
# URL of your deployed arcadia-backend. All game API calls are forwarded here.
# Local dev: run arcadia-backend on a separate port and point here.
# Production (Vercel): set this to your Render/Railway backend URL.
BACKEND_URL=https://your-backend.up.railway.app

# =============================================================================
# Celo (EVM) — public, safe to expose
# =============================================================================
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_CELO_NETWORK=mainnet
# QuizArcade v2 address. v2 is multi-token — one contract handles USDm, USDC, and USDT.
NEXT_PUBLIC_ARCADE_ADDRESS=0x0000000000000000000000000000000000000000
# Token addresses (defaults to canonical mainnet addresses if unset).
NEXT_PUBLIC_CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
NEXT_PUBLIC_TOKEN_ADDRESS_USDC=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
NEXT_PUBLIC_TOKEN_ADDRESS_USDT=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e
NEXT_PUBLIC_RPC_URL=https://forno.celo.org

# =============================================================================
# NOTE: There are NO server secrets in this repo.
# SETTLEMENT_SIGNER_PRIVATE_KEY, HIRO_API_KEY, and all leaderboard indexer config
# belong ONLY in arcadia-backend's environment. Never set them here.
# =============================================================================
